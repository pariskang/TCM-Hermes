  "original_evidence": [
    {
      "book_title": "外科正宗",
      "chapter_title": "疥瘡論第七十三",
      "dynasty": "明",
      "source_unit_id": "SU_B378970CB_002112",
      "entry_id": "PSORIASIS_000991",
      "evidence_span": "消風散內歸生地　蟬脫荊防蒼苦參胡麻知母牛蒡等　石膏甘草木通行治風濕浸淫血脈，致生瘡疥，搔癢不絕，及大人小兒風熱癮疹，遍身雲片斑點，乍有乍無並效。",
      "release_level": "silver"
    },
    {
      "book_title": "瘍科心得集",
      "chapter_title": "補遺",
      "dynasty": "清",
      "source_unit_id": "SU_BB130CD90_000956",
      "entry_id": "PSORIASIS_004360",
      "evidence_span": "治風濕浸淫血脈，致生瘡疥，搔癢無度，及大人小兒風熱，癮疹遍身雪片，斑點乍有乍無，並效。",
      "release_level": "silver"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "疥癬論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_001050",
      "entry_id": "PSORIASIS_003244",
      "evidence_span": "夫疥癬者，皆由脾經濕熱及肺氣風毒，客於肌膚所故也。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "諸疳瘡論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_000748",
      "entry_id": "PSORIASIS_003158",
      "evidence_span": "夫疳瘡有數種，有血疳、風疳、牙疳、下疳之類。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "癬",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_001925",
      "entry_id": "PSORIASIS_001206",
      "evidence_span": "一、胎癬，俗名奶癬，生嬰兒頭面，或生眉端，搔癢流脂成片，久則延及遍身。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "大麻瘋門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_010876",
      "entry_id": "PSORIASIS_002341",
      "evidence_span": "紫云瘋　此證素因氣血虛而多火，動徹則汗雨淋漓，然氣虛則腠理疏，而衣被之濕易侵皮膚，隨又復感風邪，風與濕搏，凝滯於皮膚之間，久則生蟲，致起紫黑斑點，延漫遍身，似霞如云，非癬非疥，時作痛癢，久則高腫，漸作麻木，以致喪身害命者，百有四五。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "疥癬論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_001120",
      "entry_id": "PSORIASIS_003269",
      "evidence_span": "治面上熱瘡似癬，或生赤黑斑點。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "新增江蘇揚州府江、甘、儀三邑婦女香港腳門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_010453",
      "entry_id": "PSORIASIS_002306",
      "evidence_span": "至於經紀小戶，婦女非勤於針工，即勞於操作，便得菜飯充腸，一衫蔽體，既無分外之求，更無奢靡之想，筋骨雖勞，氣血反暢，藜藿充飢，脾無壅滯，縱有濕熱相干，輕則生瘡患疥，甚則腿腳紅腫而已，香港腳之邪未能干犯也。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科正宗",
      "chapter_title": "奶癬第一百五",
      "dynasty": "明",
      "source_unit_id": "SU_B378970CB_002387",
      "entry_id": "PSORIASIS_001047",
      "evidence_span": "奶癬，兒在胎中，母食五辛，父餐炙爆，遺熱與兒，生後頭面遍身發為奶癬，流脂成片，睡臥不安，搔癢不絕。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "癰疽就簡",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_000108",
      "entry_id": "PSORIASIS_001120",
      "evidence_span": "隨處可生，而生於頭面者居多。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "異痘須知（《錦囊》）",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_012149",
      "entry_id": "PSORIASIS_002534",
      "evidence_span": "單鎖口：面部俱稀，嘴角有一粒黑痘獨大者，此名單鎖口。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "戀眉瘡門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_004097",
      "entry_id": "PSORIASIS_001771",
      "evidence_span": "申斗垣曰：兒在胎中，母食五辛，父飧炙　，遺熱與兒，生後眉間如癬，流脂成片，搔癢不絕，名曰戀眉瘡，又名煉眉瘡，（《啟玄》）",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "濕陰瘡門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_009613",
      "entry_id": "PSORIASIS_002191",
      "evidence_span": "李東垣曰：濕陰瘡由腎經虛弱，風濕相搏，邪氣乘之，瘙癢成瘡，浸淫汗出，狀如疥癬者是也。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "大麻瘋門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_010842",
      "entry_id": "PSORIASIS_002331",
      "evidence_span": "又曰：大風證者，所因不一，或色欲當風，或醉臥濕地，或乘熱脫衣，或汗出入水，或空心飢餓，山行感山嵐瘴氣，或勞役奔走，途中冒寒雨陰露，皆由內傷形體，不知避忌，外感風濕毒瓦斯，入於皮毛血脈肌肉筋骨之間，當時失於驅散，停積既久，以致榮衛不行，內外熏蒸，內則生蟲，外則生瘡，臟腑經絡皆受患矣。",
      "release_level": "bronze"
    }
  ],
