{
  "skill_id": "hermes.disease.psoriasis.erythrodermic",
  "kind": "disease",
  "disease_id": "psoriasis",
  "subtype": "erythrodermic",
  "title": "银屑病·红皮病型 古籍证候 Skill",
  "subject": "银屑病·红皮病型",
  "abstracted_claim": "古籍中与银屑病·红皮病型表型相似的条文，核心古病名 瘡、癬、疥；常见症候 遍身、浸淫、成片、斑點、頭、眉；病机多属 風濕、風熱、濕熱、風毒；高频药物 甘草、知母、石膏、苦參、文蛤、雄黃、桔梗、川芎。（候选/表型对应，非诊断）",
  "merged_rule_id": "hermes.disease.psoriasis.erythrodermic",
  "release_level": "bronze",
  "consensus_score": 0.702,
