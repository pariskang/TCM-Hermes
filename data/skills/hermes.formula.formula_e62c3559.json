    },
    {
      "book_title": "傷寒貫珠集",
      "chapter_title": "厥陰溫法九條",
      "source_unit_id": "SU_SHL_GUANZHU_000481",
      "evidence_span": "手足厥寒，脈細欲絕者，當歸四逆湯主之，若其人內有久寒者，宜當歸四逆，加吳茱萸生薑湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "宜溫經論",
      "source_unit_id": "SU_B9119D083_000025",
      "evidence_span": "少陰病脈沉者，急溫之，宜四逆湯。少陰病飲食入口即吐，若膈上有寒，飲乾嘔者，不可吐，急溫之。少陰病下利脈微澀，嘔而汗出，必數更衣，反少者，當溫之。厥陰病手足厥寒，脈細欲絕者，當歸四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "四逆證",
      "source_unit_id": "SU_B3E520529_000092",
      "evidence_span": "四逆湯治病發熱頭痛，脈反沉，若不差，身體疼痛者，脈浮遲，表熱裏寒，下利清穀者，汗出熱不去，內拘急，支節疼，四逆者下利厥逆，惡寒者下利腹脹滿，身疼脈浮者先用四逆溫裏，得利止，乃可隨證用藥攻表也。甘草〔壹兩〕、附子〔半個〕、乾薑〔參分〕，㕮咀，以水壹升半，煮取陸合，去滓，溫分作貳服。手足厥，脈微欲絕者，當歸四逆湯主之。",
      "release_level": "silver"
    }
