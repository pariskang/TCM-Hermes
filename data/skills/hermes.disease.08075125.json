      "source_unit_id": "SU_B0B74DF58_000226",
      "evidence_span": "**五十一、結胸證，其脈浮大者，不可下，下之則死。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論辯證廣注",
      "chapter_title": "",
      "source_unit_id": "SU_B41512D4B_000895",
      "evidence_span": "結胸熱實。脈沉而緊。心下痛按之石硬者。大陷胸湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論",
      "chapter_title": "",
      "source_unit_id": "SU_B5FF1CA1B_000439",
      "evidence_span": "不結胸。心中懊　。飢不能食但頭汗出者。梔子豉湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000029",
      "evidence_span": "結胸症，脈浮大，不可下。陽明病，面赤色，表症也，不可下。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論綱目",
      "chapter_title": "",
      "source_unit_id": "SU_B3E16D849_000882",
      "evidence_span": "結胸無大熱。但頭微汗出者。此為水結在胸脅也。大陷胸湯主之。",
      "release_level": "silver"
    },
