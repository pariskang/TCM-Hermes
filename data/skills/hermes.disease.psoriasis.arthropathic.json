  "original_evidence": [
    {
      "book_title": "瘍醫大全",
      "chapter_title": "結毒門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_013406",
      "entry_id": "PSORIASIS_002753",
      "evidence_span": "劉惠田曰：但凡曾患楊梅瘡下疳服藥而愈，久後如患後開十數證者，勿作他治，皆結毒證也。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "痛風門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_010736",
      "entry_id": "PSORIASIS_002324",
      "evidence_span": "《統旨》曰：風痹者，游行上下，隨其虛邪與血氣相搏，聚於關節、筋脈，弛縱而不收也。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "大麻瘋門主方",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_011086",
      "entry_id": "PSORIASIS_002353",
      "evidence_span": "（如身發多瘡，或生濕毒通身，如蛇皮，或破流血水者，是脾經受毒，加白朮十兩。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科正宗",
      "chapter_title": "楊梅瘡論第三十六",
      "dynasty": "明",
      "source_unit_id": "SU_B378970CB_001654",
      "entry_id": "PSORIASIS_000937",
      "evidence_span": "加味遺糧湯木瓜　芎歸防苡術銀花癬皮皂子靈仙等　木通甘草共參夸示楊梅瘡初起筋骨疼痛，及已成數月，延綿不已。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "瘡科總論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_000005",
      "entry_id": "PSORIASIS_003021",
      "evidence_span": "瘡者，其總名也。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科大成",
      "chapter_title": "內癰總論",
      "dynasty": "清",
      "source_unit_id": "SU_B78ADD200_003334",
      "entry_id": "PSORIASIS_003641",
      "evidence_span": "夫梅瘡言形也。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "破傷風治法",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_000061",
      "entry_id": "PSORIASIS_001114",
      "evidence_span": "破傷風者，因跌撲金刃傷破皮肉，及新久諸瘡未合口，失於調護，風邪乘虛襲入經絡，宜亟，皆莫救矣。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科精要",
      "chapter_title": "馬益卿先生癰疽論第十二",
      "dynasty": "宋",
      "source_unit_id": "SU_BCAE191F2_000150",
      "entry_id": "PSORIASIS_004830",
      "evidence_span": "論曰：夫人有四肢、五臟，一覺一寐，呼吸吐納、精氣往來、流而為榮衛，暢而為氣色，發而為聲音，陽用其形，陰用其精，此又常數之所同也。",
      "release_level": "bronze"
    }
  ],
