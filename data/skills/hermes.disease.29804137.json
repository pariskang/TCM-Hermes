  "original_evidence": [
    {
      "book_title": "傷寒六書",
      "chapter_title": "",
      "source_unit_id": "SU_BBA9FB4A6_000999",
      "evidence_span": "濕家之為病，一分盡痛，發熱，身雖如似熏黃，小便不利，五苓散；",
      "release_level": "gold"
    },
    {
      "book_title": "傷寒來蘇集",
      "chapter_title": "",
      "source_unit_id": "SU_SHL_LAISU_000528",
      "evidence_span": "傷寒陰陽易之為病，其人身體重，少氣，少腹裏急，小便不利，陰中拘攀，熱上衝胸，頭重不欲舉，眼中生花，膝脛拘急者，燒褌散主之。",
      "release_level": "gold"
    },
    {
      "book_title": "傷寒論注",
      "chapter_title": "",
      "source_unit_id": "SU_SHL_LUNZHU_001310",
      "evidence_span": "傷寒陰陽易之為病，其人身體重，少氣，少腹裡急，小便不利，陰中拘攣，熱上衝胸，頭重不欲舉，眼中生花，膝脛拘急者，燒　散主之。",
      "release_level": "gold"
    },
    {
      "book_title": "傷寒捷訣",
      "chapter_title": "",
      "source_unit_id": "SU_B18FAB5FB_000175",
      "evidence_span": "小便不利。心中懊惱者。必發黃。宜茵陳蒿湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_001496",
      "evidence_span": "渴而小便不利。膀胱虛寒，欬而小便利，俱在禁汗例。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒捷訣",
      "chapter_title": "",
      "source_unit_id": "SU_B18FAB5FB_000008",
      "evidence_span": "他如發熱煩渴。小便不利。此為熱入膀胱之本。宜五苓散主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_001077",
      "evidence_span": "若飲而腹滿，小便不利，若喘若噦，不可與之，忽然大汗出，是為自愈也。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000549",
      "evidence_span": "少陰病，二三日至四五日，腹痛小便不利，下利不止，便膿血者，桃花湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000538",
      "evidence_span": "少陰病，四逆，其人或咳或悸，或小便不利，或腹中痛，或泄利下重者，四逆散主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000712",
      "evidence_span": "本以下之，故心下痞，與瀉心湯痞不解，其人渴而口躁煩，小便不利者，五苓散主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001357",
      "evidence_span": "**八、少陰病，二三日至四五者，腹痛，小便不利，下利不止，便膿血者，桃花湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000435",
      "evidence_span": "傷寒八九日，下之胸滿煩驚，小便不利，讝語，一身盡重，不可轉側者，柴胡加龍骨牡蠣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000564",
      "evidence_span": "**五十七、傷寒七八日，身黃如**（紫）〔橘子〕**色，小便不利，腹微滿者，茵陳篙湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000072",
      "evidence_span": "傷寒表不解，心下有水氣，乾嘔發熱而咳，或渴或利或噎，或小便不利，少腹滿或喘者，小青龍湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000119",
      "evidence_span": "太陽病，身黃脈沉結，少腹鞕小便不利者，為無血也，小便自利，其人如狂者，血證諦也，抵當湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000448",
      "evidence_span": "**四十二、傷寒八九日，下之，胸滿煩驚，小便不利，譫語，一身盡重，不可轉側者，柴胡加龍骨牡蠣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000211",
      "evidence_span": "風濕相搏，骨節煩疼，製痛不得屈伸，近之則痛劇，汗出短氣，小便不利惡風不欲去衣，或身微腫者，甘草附子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001403",
      "evidence_span": "**十三、少陰病，四逆，其人或咳、或悸、或小便不利，或腹中痛，或**（上輕）〔泄利〕**下重者，四逆散主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000625",
      "evidence_span": "**十、服桂枝湯，或下之，仍頭痛、項強、翕翕發熱，無汗，心下滿，微痛，小便不利者，桂枝湯去桂加茯苓白朮湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000182",
      "evidence_span": "傷寒七八日，身黃如橘子色，小便不利，腹微滿者，茵陳蒿湯主之，小便當利，尿如皂角汁狀，色正赤，一宿腹減，黃從小便去也。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001404",
      "evidence_span": "其中或咳或悸者，水氣上干也；小便不利者，陽不化陰也；腹痛下重，陰寒之極也。法宜大劑回陽為是，而此以四逆散主之，吾甚不解。",
      "release_level": "silver"
