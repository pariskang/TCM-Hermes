  "original_evidence": [
    {
      "book_title": "諸病源候論",
      "chapter_title": "瘡病諸候·乾癬候",
      "dynasty": "隋",
      "source_unit_id": "SU_PSORIASIS_SAMPLE_0001",
      "entry_id": "PSORIASIS_000001",
      "evidence_span": "乾癬，但有匡郭，皮枯索，痒，搔之白屑出是也。",
      "release_level": "silver"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "白疕",
      "dynasty": "清",
      "source_unit_id": "SU_PSORIASIS_SAMPLE_0006",
      "entry_id": "PSORIASIS_000006",
      "evidence_span": "白疕，皮膚燥癢，起如疹疥而色白，搔之屑起，漸至成片，由血虛風燥所致，治宜養血潤燥祛風。",
      "release_level": "bronze"
    },
    {
      "book_title": "諸病源候論",
      "chapter_title": "瘡病諸候·濕癬候",
      "dynasty": "隋",
      "source_unit_id": "SU_PSORIASIS_SAMPLE_0002",
      "entry_id": "PSORIASIS_000002",
      "evidence_span": "濕癬者，亦有匡郭，如蟲行，浸淫，赤濕，痒，搔之多汁成瘡，是其風毒氣淺，濕氣多故也。",
      "release_level": "bronze"
    },
    {
      "book_title": "醫宗金鑒",
      "chapter_title": "外科心法要訣·白疕",
      "dynasty": "清",
      "source_unit_id": "SU_PSORIASIS_SAMPLE_0004",
      "entry_id": "PSORIASIS_000004",
      "evidence_span": "白疕，俗名蛇虱，生於皮膚，形如疹疥，色白而癢，搔起白皮。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "牛皮癬門",
      "dynasty": "清",
      "source_unit_id": "SU_PSORIASIS_SAMPLE_0007",
      "entry_id": "PSORIASIS_000007",
      "evidence_span": "牛皮癬，狀如牛項之皮，厚而且堅，頑癬之類也，搔之不知痛癢，宜外用殺蟲潤燥之藥。",
      "release_level": "bronze"
    }
