  "original_evidence": [
    {
      "book_title": "外科證治全書",
      "chapter_title": "癬",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_001920",
      "entry_id": "PSORIASIS_001204",
      "evidence_span": "初起如錢，漸漸增長，或圓或歪，有匡廓，癢痛不一，其證有六：一曰干癬，搔癢則起白屑，搔之痹頑，不知痛癢；",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "疥瘡門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_013604",
      "entry_id": "PSORIASIS_002795",
      "evidence_span": "《心法》曰：疥有干、濕、蟲、沙、膿五種。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科正宗",
      "chapter_title": "頑癬第七十六",
      "dynasty": "明",
      "source_unit_id": "SU_B378970CB_002163",
      "entry_id": "PSORIASIS_001012",
      "evidence_span": "頑癬乃風、熱、濕、蟲四者為患。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "痧疹門",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_012884",
      "entry_id": "PSORIASIS_002628",
      "evidence_span": "初見如疥如米尖；",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "疥瘡",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_001938",
      "entry_id": "PSORIASIS_001211",
      "evidence_span": "疥證有五，干、濕、沙、蟲、膿也，皆由氣虛血熱，榮衛不清之故，每先從手丫生起，延繞周身，搔癢無度。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科正宗",
      "chapter_title": "白屑風第八十四",
      "dynasty": "明",
      "source_unit_id": "SU_B378970CB_002261",
      "entry_id": "PSORIASIS_001024",
      "evidence_span": "祛風換肌丸蒼朮　首烏牛膝石菖蒲苦參甘草靈仙等　芎歸花粉共相和治白屑風及紫白癜風、頑風頑癬、濕熱瘡疥、一切諸瘡，搔癢無度，日久不絕，愈之又發宜服之。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "惡瘡門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_013977",
      "entry_id": "PSORIASIS_002916",
      "evidence_span": "然有辨焉，如疥癬癮疹之屬，拂鬱氣血，在皮膚腠理間者，可以表而散，《內經》有謂汗之則瘡已是矣。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科大成",
      "chapter_title": "無名腫毒",
      "dynasty": "清",
      "source_unit_id": "SU_B78ADD200_003898",
      "entry_id": "PSORIASIS_003706",
      "evidence_span": "癬發於肺之瘋毒。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍科心得集",
      "chapter_title": "辨諸瘡總論",
      "dynasty": "清",
      "source_unit_id": "SU_BB130CD90_000243",
      "entry_id": "PSORIASIS_004282",
      "evidence_span": "夫惡瘡，諸痛癢瘡，皆屬於心；",
      "release_level": "bronze"
    },
    {
      "book_title": "外科正宗",
      "chapter_title": "鵝掌風第七十一",
      "dynasty": "明",
      "source_unit_id": "SU_B378970CB_002096",
      "entry_id": "PSORIASIS_000988",
      "evidence_span": "鵝掌風由手陽明、胃經火熱血燥，外受寒涼所凝，致皮枯槁；",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "癰疽證治統論",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_000002",
      "entry_id": "PSORIASIS_001098",
      "evidence_span": "外紅裡黑者，毒滯不化也；",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "論癢",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_000025",
      "entry_id": "PSORIASIS_001108",
      "evidence_span": "他如皮膚搔癢，由血燥而風生，疥癬延綿，屬風淫而蟲蝕。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "白屑風門主方",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_004013",
      "entry_id": "PSORIASIS_001763",
      "evidence_span": "（《正宗》）　治白屑風及紫白癜瘋，頑風頑癬，濕熱瘡疥，一切諸瘡，搔癢無度，日久不絕，愈之又發者，極宜之。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科大成",
      "chapter_title": "脛部",
      "dynasty": "清",
      "source_unit_id": "SU_B78ADD200_002231",
      "entry_id": "PSORIASIS_003536",
      "evidence_span": "治血燥膚癢。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科大成",
      "chapter_title": "頭部",
      "dynasty": "清",
      "source_unit_id": "SU_B78ADD200_002396",
      "entry_id": "PSORIASIS_003565",
      "evidence_span": "治白屑風紫白癜風。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍科心得集",
      "chapter_title": "辨濕毒瘡腎臟風瘡論",
      "dynasty": "清",
      "source_unit_id": "SU_BB130CD90_000255",
      "entry_id": "PSORIASIS_004294",
      "evidence_span": "腎臟風者，屬腎虛，風邪乘於　脛，以致皮膚如癬，或漸延上腿，久則延久遍身。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科樞要",
      "chapter_title": "論腎臟風瘡（九）",
      "dynasty": "明",
      "source_unit_id": "SU_BF32DDC4C_000356",
      "entry_id": "PSORIASIS_005033",
      "evidence_span": "腎臟風屬腎虛，風邪乘於　脛，以致皮膚如癬，或漸延上腿，久則延及遍身。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "癢風",
      "dynasty": "清",
      "source_unit_id": "SU_B4E954120_002055",
      "entry_id": "PSORIASIS_001224",
      "evidence_span": "遍身搔癢，並無瘡疥，搔之不止。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科大成",
      "chapter_title": "手部",
      "dynasty": "清",
      "source_unit_id": "SU_B78ADD200_002035",
      "entry_id": "PSORIASIS_003522",
      "evidence_span": "久則皮枯堅濃。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "腎臟風瘡門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_010299",
      "entry_id": "PSORIASIS_002289",
      "evidence_span": "王肯堂曰：腎臟風屬腎，虛風邪乘於　脛，以致皮膚如癬，或漸延上腿，久則延及遍身，外證則瘙癢成瘡，膿水淋漓，眼目昏花，內證則口燥舌乾，腰腿倦怠，吐痰發熱，盜汗體疲，治當用六味地黃丸。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "跌打損傷門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_014093",
      "entry_id": "PSORIASIS_002938",
      "evidence_span": "又云：凡傷損之證，遍身作癢，或搔破如瘡疥，此血不營於肌腠，當作血虛治之。",
      "release_level": "bronze"
    }
  ],
