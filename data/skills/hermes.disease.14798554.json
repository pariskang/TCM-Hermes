    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000483",
      "evidence_span": "少陰病下利，白通湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000576",
      "evidence_span": "下利清穀，不可攻表，汗出必脹滿。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000584",
      "evidence_span": "大汗若大下利而厥冷者，四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001265",
      "evidence_span": "**十三、少陰病，下利，白通湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000647",
      "evidence_span": "下利欲飲水者，以有熱故也，白頭翁湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001556",
      "evidence_span": "**十五、下利清穀，不可攻表，汗出必脹滿。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001360",
      "evidence_span": "**九、少陰病，下利，便膿血者，桃花湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001506",
      "evidence_span": "**二、大汗，若大下利，而厥冷者，四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001108",
      "evidence_span": "**四、太陽與陽明合病者，必自下利，葛根湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001579",
      "evidence_span": "**四、下利欲飲水者，以有熱故也，白頭翁湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000572",
      "evidence_span": "下利清穀，裏寒外熱，汗出而厥者，通脈四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000551",
      "evidence_span": "少陰病，下利便膿血者，桃花湯主之，少陰病，便膿血者可刺。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001544",
      "evidence_span": "**十一、下利清穀，裏寒外熱，汗出而厥者，通脈四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001557",
      "evidence_span": "【鄭論】　按下利清穀，裏寒之極也，原文不可攻表，此是正論。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000582",
      "evidence_span": "大汗出，熱不去內拘急，四肢疼又下利厥逆而惡寒者，四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001368",
      "evidence_span": "**十、少陰病，下利、咽痛，胸滿、心煩**（者）**豬膚湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001411",
      "evidence_span": "**十四、少陰病，下利六七日，咳而嘔渴，心煩不得眠者，豬苓湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000812",
      "evidence_span": "**二十五、脈浮而遲，表熱裏寒，下利清穀**〔者〕**，四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000409",
      "evidence_span": "**三十四、傷寒發熱，汗出不解，心中痞鞭，嘔吐而下利者，大柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000549",
      "evidence_span": "少陰病，二三日至四五日，腹痛小便不利，下利不止，便膿血者，桃花湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000590",
      "evidence_span": "既吐且利，小便復利而大汗出，下利清穀，內寒外熱，脈微欲絕者，四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001114",
      "evidence_span": "**六、太陽與少陽合病，自下利者，與黃芩湯，若嘔者，黃芩加半夏生薑湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001503",
      "evidence_span": "**一、大汗出，熱不去，內拘急①，四肢疼，又下利厥逆而惡寒者，四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000614",
      "evidence_span": "下利脈大者，虛也，以其強下之故也，設脈浮革，因爾腸鳴者，屬當歸四逆湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000294",
      "evidence_span": "脈浮而遲，表熱裏寒，下利清穀者，四逆湯主之，若胃中虛冷，不能食者，飲水則噦。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001357",
      "evidence_span": "**八、少陰病，二三日至四五者，腹痛，小便不利，下利不止，便膿血者，桃花湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001273",
      "evidence_span": "**十四、少陰病，下利，脈微者，與白通湯；利不止，厥逆無脈，乾嘔煩者，白通加豬膽汁湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000694",
      "evidence_span": "傷寒汗出解之後，胃中不和，心下痞鞕，乾噫食臭，脇下有水氣，腹中雷鳴下利者，生薑瀉心湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001557",
      "evidence_span": "【鄭論】　按下利清穀，裏寒之極也，原文不可攻表，此是正論。攻之必汗出脹滿，是教人不可妄攻也。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001100",
      "evidence_span": "**三、太陽與陽明合病，**（則）**不下利**（而）〔但〕**嘔者，**（用）**葛根加半夏湯主之。",
      "release_level": "silver"
    }
