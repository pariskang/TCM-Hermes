  "original_evidence": [
    {
      "book_title": "傷寒百證歌",
      "chapter_title": "第七十八證‧舌上苔歌",
      "source_unit_id": "SU_BB7301DF2_000232",
      "evidence_span": "仲景云。陽明。心中懊　舌上苔者。梔子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒直格",
      "chapter_title": "懊",
      "source_unit_id": "SU_BC3C734B7_000363",
      "evidence_span": "或胸滿結滯，或頭微汗出，劇煩者，梔子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "發汗吐下後雜病證",
      "source_unit_id": "SU_BC2BA03C0_000628",
      "evidence_span": "發汗，若下之，而煩熱，胸中窒塞者，梔子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "厥陰病狀第三",
      "source_unit_id": "SU_SHL_QJYF_000373",
      "evidence_span": "下利後更煩，按其心下濡者，為虛煩也，梔子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒百證歌",
      "chapter_title": "第七十六證‧頭汗歌",
      "source_unit_id": "SU_BB7301DF2_000227",
      "evidence_span": "心中懊　。若飢不能食。但頭有汗出者。宜用梔子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "陽明病狀第八",
      "source_unit_id": "SU_SHL_QJYF_000203",
      "evidence_span": "陽明病，下之，其外有熱，手足溫，不結胸，心中懊　，若飢不能食，但頭汗出，梔子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "發汗吐下後雜病證",
      "source_unit_id": "SU_B3E520529_000131",
      "evidence_span": "凡用梔子湯得效，即止後服，病人舊有微溏，不可與之。發汗若下之而煩熱，胸中窒塞者，梔子湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒直格",
      "chapter_title": "（第十四節）懊憹",
      "source_unit_id": "SU_BEF4B02F4_000325",
      "evidence_span": "或胸滿結滯，或頭微汗出虛煩者，梔子湯主之，或少氣者加甘草一錢，或加嘔者及初誤以圓藥下之者加生薑半兩，凡懊憹虛煩者，皆用涼膈散甚佳，及宜湯濯手足，使心胸結熱宣散而已。",
      "release_level": "silver"
    }
