      "release_level": "silver"
    },
    {
      "book_title": "傷寒發微論",
      "chapter_title": "論傷寒七十二證候",
      "source_unit_id": "SU_B9FC1D1C8_000063",
      "evidence_span": "心下悸動（傷寒脈結代。心下悸動者。炙甘草湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論綱目",
      "chapter_title": "厥陰經脈",
      "source_unit_id": "SU_B3E16D849_003782",
      "evidence_span": "【綱】仲景曰。傷寒脈結代。心動悸者。炙甘草湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "曹氏傷寒金匱發微合刊",
      "chapter_title": "少陽篇",
      "source_unit_id": "SU_CAOSHI_FAWEI_000731",
      "evidence_span": "心營耗損。煩熱而動悸。此證脈結代。則炙甘草湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論輯義",
      "chapter_title": "辨太陽病脈證並治下",
      "source_unit_id": "SU_BBAACE965_001985",
      "evidence_span": "為陰盛之脈。故謂之代陰也。上文雖云脈結代者。皆以炙甘草湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒捷訣",
      "chapter_title": "心動悸",
      "source_unit_id": "SU_B18FAB5FB_000165",
      "evidence_span": "此陽氣虛也。宜小建中湯主之。有因傷寒脈結代而心動悸者。宜炙甘草湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒雜病論(桂本)",
      "chapter_title": "辨咳嗽水飲黃汗歷節病脈證並治",
      "source_unit_id": "SU_SHL_GUIBEN_001219",
      "evidence_span": "14.25咳而唾涎沫不止，咽燥，口渴，其脈浮細而數者，此為肺痿，炙甘草湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "經方實驗錄",
      "chapter_title": "第五六案　炙甘草湯證　其二穎師醫案",
      "source_unit_id": "SU_JF_SHIYANLU_000327",
      "evidence_span": "唐左，初診，十月二十日，脈結代，心動悸，炙甘草湯主之，此仲景先師之法，不可更變者也。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "太陽中篇",
      "source_unit_id": "SU_B0B74DF58_000456",
      "evidence_span": "**四十三、傷寒脈結代**(是結脈和代脈的並稱。景岳說：「脈來忽止，止而復起，總謂之結。」代者更代之意，於平脈中忽見軟弱，或乍疏乍數，或斷而復起，均名為代)**，心動悸**（者）**，炙甘草湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "經方實驗錄",
      "chapter_title": "第五五案　炙甘草湯證　其一穎師講授　佐景筆記",
      "source_unit_id": "SU_JF_SHIYANLU_000323",
      "evidence_span": "**師曰：**律師姚建，現住小西門外大興街，嘗來請診，眠食無恙，按其脈結代，約十餘至一停，或二三十至一停不等，又以事繁，心常跳躍不寧，此仲師所謂心動悸，脈結代，炙甘草湯主之之證是也，因書經方與之，服十餘劑而瘥。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "辨舌",
      "source_unit_id": "SU_B11498305_001489",
      "evidence_span": "灰黑舌者，足三陰互痛如以青和入黑中則為灰色也，然有傳經直中之殊，蓋傳經熱邪始自白胎而黃，黃而灰黑或生芒刺，黑點紋裂乾燥，不拘在根在尖，俱宜攻下泄熱有淡灰色中起深黑重暈者乃溫病，熱毒急用涼膈雙解治之，熱毒內傳一次，見暈一重傳二三次，見二三重也，若見三重者不治，若直中三陰始病無躁熱便見灰色舌潤無胎，更不變別色者，此必內夾寒食及冷痰水飲或畜水如狂等證，當隨證治之，又有感冒夾食屢汗下，消導二便已通，而古上灰黑未退，或濕潤或雖不濕亦不乾燥者，不可因其濕而誤認寒妄投薑附亦不可，因其不潤而誤與硝黃，此因汗下過傷津液，虛火上炎所致，其脈必虛微少力治宜救陰為急雖無心悸脈代，當用炙甘草湯主之，有生地阿膠麻仁麥冬之甘潤，可以滋陰潤燥，蓋陽邪亢盛，則用硝黃以救陰，陰血枯涸，則宜生地以滋陰，可不辦乎。",
      "release_level": "silver"
    }
  ],
