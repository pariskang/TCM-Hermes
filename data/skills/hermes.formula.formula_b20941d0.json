  "original_evidence": [
    {
      "book_title": "傷寒論綱目",
      "chapter_title": "循衣摸床",
      "source_unit_id": "SU_B3E16D849_002470",
      "evidence_span": "脈弦者生。澀者死。承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "太陽病用承氣湯法第五",
      "source_unit_id": "SU_SHL_QJYF_000056",
      "evidence_span": "傷寒吐後，腹滿者，承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒百證歌",
      "chapter_title": "第五十七證‧譫語歌",
      "source_unit_id": "SU_BB7301DF2_000173",
      "evidence_span": "胃中燥。大便必堅。堅者譫語。承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒百證歌",
      "chapter_title": "第五十九證‧懊歌",
      "source_unit_id": "SU_BB7301DF2_000178",
      "evidence_span": "後溏者。不可下之。有燥屎者。宜承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒九十論",
      "chapter_title": "懊怫鬱證（八十五）",
      "source_unit_id": "SU_B9DD8A693_000269",
      "evidence_span": "時有微熱。怫鬱不得眠者。有燥屎也。承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒百證歌",
      "chapter_title": "第六十證‧怫鬱歌",
      "source_unit_id": "SU_BB7301DF2_000179",
      "evidence_span": "時有微熱。怫鬱不得臥。有燥屎故也。承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒百證歌",
      "chapter_title": "第五十七證‧譫語歌",
      "source_unit_id": "SU_BB7301DF2_000173",
      "evidence_span": "或因下利或胃實。（仲景云。下利而譫語為有燥屎。承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒六書",
      "chapter_title": "怫鬱",
      "source_unit_id": "SU_BBA9FB4A6_001025",
      "evidence_span": "小便不利，時有微熱，大便乍難，怫鬱不得臥，此燥屎裡實也，承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "陽明病狀第八",
      "source_unit_id": "SU_SHL_QJYF_000186",
      "evidence_span": "陽明病，其人多汗，津液外出，胃中燥，大便必堅，堅者則譫語，承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "陽明病狀第八",
      "source_unit_id": "SU_SHL_QJYF_000188",
      "evidence_span": "陽明病，譫語，有潮熱，反不能食者，必有燥屎五六枚，若能食者，但堅耳，承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "陽明病狀第八",
      "source_unit_id": "SU_SHL_QJYF_000181",
      "evidence_span": "陽明病，其脈遲，雖汗出，不惡寒，其體必重，短氣，腹滿而喘，有潮熱，如此者，其外為解，可攻其裡，手足　然汗出，此為已堅，承氣湯主之。",
      "release_level": "silver"
    }
  ],
