  "original_evidence": [
    {
      "book_title": "時病論",
      "chapter_title": "溫毒",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000023",
      "entry_id": "WARM_DISEASE_000011",
      "evidence_span": "溫毒者，由於冬令過暖，人感乖戾之氣，至春夏之交，更感溫熱，伏毒自內而出，表裡皆熱。",
      "release_level": "silver"
    },
    {
      "book_title": "溫熱經緯",
      "chapter_title": "方論",
      "dynasty": "清",
      "source_unit_id": "SU_BFAA96A43_001478",
      "entry_id": "WARM_DISEASE_001516",
      "evidence_span": "雄按：此治濕溫時疫之主方也。",
      "release_level": "silver"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "春溫條辨第十九",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000048",
      "entry_id": "WARM_DISEASE_000380",
      "evidence_span": "風溫犯肺，熱壅上焦，故初起面目俱赤，咳涕咽疼，皆手太陰見症。",
      "release_level": "silver"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "二十二、論伏氣發溫與暴感風溫病源不同治法各異",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000346",
      "entry_id": "WARM_DISEASE_000684",
      "evidence_span": "冬時伏邪，鬱伏至春夏，陽氣內動，化熱外達，此伏氣所發之溫病也。",
      "release_level": "silver"
    },
    {
      "book_title": "溫熱逢源",
      "chapter_title": "論伏氣發溫與暴感風溫病原不同治法各異",
      "dynasty": "清",
      "source_unit_id": "SU_BBDFA4EA7_000350",
      "entry_id": "WARM_DISEASE_000953",
      "evidence_span": "冬時伏邪，鬱伏至春夏，陽氣內動，化熱外達，此伏氣所發之溫病也。",
      "release_level": "silver"
    },
    {
      "book_title": "溫熱經緯",
      "chapter_title": "薛生白濕熱病篇",
      "dynasty": "清",
      "source_unit_id": "SU_BFAA96A43_000884",
      "entry_id": "WARM_DISEASE_001491",
      "evidence_span": "○《醫師秘籍》僅載前三十五條，江白仙本與《溫熱贅言》於三十五條止采二十條，而多後之十一條，且編次互異，無從訂正，偶於友人顧聽泉學博處見鈔本。",
      "release_level": "silver"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "斑疹條辨第一",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000386",
      "entry_id": "WARM_DISEASE_000475",
      "evidence_span": "斑為陽明熱毒，疹為太陰風熱，總屬溫熱所化，發洩於外。",
      "release_level": "silver"
    },
    {
      "book_title": "時病論",
      "chapter_title": "風溫",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000018",
      "entry_id": "WARM_DISEASE_000006",
      "evidence_span": "風溫之病，發於當春厥陰風木行令之時，少陰君火初交之際。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000133",
      "entry_id": "WARM_DISEASE_000056",
      "evidence_span": "裡人范某，患風溫時病，藥石雜投，久延未愈。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000145",
      "entry_id": "WARM_DISEASE_000066",
      "evidence_span": "古越胡某之郎，年方舞象，忽患熱渴咳閉，已半月矣，前醫罔效，病勢日加沉重。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "冬溫",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_001089",
      "entry_id": "WARM_DISEASE_000136",
      "evidence_span": "昔賢謂冬應寒而反溫，非其時而有其氣，人感之而即病者，名曰冬溫是也。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "十五、溫熱提要",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000311",
      "entry_id": "WARM_DISEASE_000662",
      "evidence_span": "俞東扶曰：今之所謂傷寒者，大概皆溫熱病耳。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "二、風溫",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000450",
      "entry_id": "WARM_DISEASE_000756",
      "evidence_span": "凌嘉六曰：春溫者，伏氣也；",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱經緯",
      "chapter_title": "陳平伯外感溫病篇",
      "dynasty": "清",
      "source_unit_id": "SU_BFAA96A43_000627",
      "entry_id": "WARM_DISEASE_001459",
      "evidence_span": "風溫證：身大熱，口大渴，目赤唇腫，氣粗煩躁，舌絳齒板，痰咳，甚至神昏譫語，下利黃水者，風溫熱毒，深入陽明營分，最為危候。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "春溫",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000017",
      "entry_id": "WARM_DISEASE_000005",
      "evidence_span": "其初起之證，頭身皆痛，寒熱無汗，咳嗽口渴，舌苔浮白，脈息舉之有餘，或弦或緊，尋之或滑或數，此宜辛溫解表法為先；",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000131",
      "entry_id": "WARM_DISEASE_000054",
      "evidence_span": "云岫孫某，平素清　，吸煙弱質，患咳嗽熱渴，計半月矣。",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "冬溫溫毒條論",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000293",
      "entry_id": "WARM_DISEASE_000445",
      "evidence_span": "皆此類也，更有陰虧陽亢之體，陰氣暴絕，陽邪獨發，初起便目赤齒枯，舌絳口渴，斑如錦紋，神昏咽痛，脈弦數促，此名溫毒，即《傷寒例》中陽毒症也。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "二、風溫",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000434",
      "entry_id": "WARM_DISEASE_000742",
      "evidence_span": "雷少逸曰：風溫之病，發於當春厥陰風木行令之時，少陰君火初交之際。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "一、春溫",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000425",
      "entry_id": "WARM_DISEASE_000735",
      "evidence_span": "雷少逸曰：考諸大家論春溫者，惟嘉言與遠公，精且密矣。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "風熱",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000163",
      "entry_id": "WARM_DISEASE_000070",
      "evidence_span": "此不但與風溫為兩途，抑且與熱病為各異。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "八、冬溫",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000506",
      "entry_id": "WARM_DISEASE_000786",
      "evidence_span": "楊如侯曰：冬溫脈寸洪尺數，或實大，心煩、嘔逆、身熱、不惡寒，或頭痛、身重、面腫、咳嗽、咽痛、下利，此冬感非節之暖而病溫也。",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "春溫條辨第一",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000003",
      "entry_id": "WARM_DISEASE_000354",
      "evidence_span": "春溫初起，頭痛身疼，無汗惡寒，發熱目赤，口渴舌白，脈浮數，此溫邪襲衛。",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "春溫條辨第一",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000005",
      "entry_id": "WARM_DISEASE_000356",
      "evidence_span": "故見證必惡寒發熱，頭痛項強‧腰痛足酸，而陽明則在大陽之次，其經起於面，挾鼻上額循目眶，行身之前，至足內踝而終。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_001147",
      "entry_id": "WARM_DISEASE_000145",
      "evidence_span": "一日忽患冬溫，發熱咳嗽，胸閉喉疼，天癸又至。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱經緯",
      "chapter_title": "陳平伯外感溫病篇",
      "dynasty": "清",
      "source_unit_id": "SU_BFAA96A43_000605",
      "entry_id": "WARM_DISEASE_001442",
      "evidence_span": "故風溫之病，多見於此，但風邪屬陽，陽邪從陽，必傷衛氣。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱經緯",
      "chapter_title": "葉香岩外感溫熱篇",
      "dynasty": "清",
      "source_unit_id": "SU_BFAA96A43_000373",
      "entry_id": "WARM_DISEASE_001396",
      "evidence_span": "仲景辨六經證治，於一經中皆有表裡淺深之分，溫邪雖與傷寒不同，其始皆由營衛，故先生於營衛中又分氣血之淺深，精細極矣。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000135",
      "entry_id": "WARM_DISEASE_000058",
      "evidence_span": "南鄉梅某，望七之年，素來康健，微熱咳嗽，患有數朝，時逢農事方興，猶是勤耕綠野，加冒春雨，則發熱忽熾，咳嗽頻頻，口渴不甚引飲，身痛便瀉。",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "春溫條辨第十八",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000044",
      "entry_id": "WARM_DISEASE_000377",
      "evidence_span": "春溫惡寒發熱，頭痛無汗，頸頷核腫，牙關不宣，此溫邪時毒。",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "冬溫條辨第一",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000294",
      "entry_id": "WARM_DISEASE_000446",
      "evidence_span": "冬溫初起，頭痛無汗，惡寒發熱，口渴鼻乾脈數，此溫邪在表。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "一、春溫",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000427",
      "entry_id": "WARM_DISEASE_000737",
      "evidence_span": "楊如侯曰：太陰之為病，脈不緩不緊而動數，或兩寸獨大，尺膚熱，頭痛，身熱，口渴，午後熱甚，名曰溫病。",
      "release_level": "bronze"
    }
  ],
