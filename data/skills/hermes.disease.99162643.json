  "original_evidence": [
    {
      "book_title": "傷寒法祖",
      "chapter_title": "",
      "source_unit_id": "SU_B294D68B8_000047",
      "evidence_span": "陽明中風。脈弦浮大不得汗。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論辯證廣注",
      "chapter_title": "",
      "source_unit_id": "SU_B41512D4B_000993",
      "evidence_span": "傷寒中風者。是互言以見二證之皆不可下也。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論辯證廣注",
      "chapter_title": "",
      "source_unit_id": "SU_B41512D4B_001348",
      "evidence_span": "此是陽明中風。仲景法。宜桂枝加葛根湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "曹氏傷寒金匱發微合刊",
      "chapter_title": "",
      "source_unit_id": "SU_CAOSHI_FAWEI_002099",
      "evidence_span": "產後中風發熱，面正赤，喘而頭痛，竹葉湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_001385",
      "evidence_span": "陽明中風，脈弦浮大，而短氣腹滿，脅下及心痛，鼻干不得汗。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000119",
      "evidence_span": "太陽病，頭痛發熱，汗出惡風，脈浮緩者，名中風，桂枝湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000405",
      "evidence_span": "少陽中風，兩耳無所聞，目赤，胸中滿而煩者，不可吐下，吐下則悸而驚。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論辯證廣注",
      "chapter_title": "",
      "source_unit_id": "SU_B41512D4B_000711",
      "evidence_span": "（重出例）中風發熱六七日不解（云云至）名曰水逆五苓散主之（已見前）",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論辯證廣注",
      "chapter_title": "",
      "source_unit_id": "SU_B41512D4B_000788",
      "evidence_span": "中風。往來寒熱胸脅苦滿。（云云至）身有微熱或咳者。與小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "",
      "source_unit_id": "SU_B3E520529_000035",
      "evidence_span": "少陽中風，兩耳微聞，目赤，胸中滿而煩，不可吐下，吐下則驚悸，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "",
      "source_unit_id": "SU_B3E520529_000035",
      "evidence_span": "少陽中風，兩耳微聞，目赤，胸中滿而煩，不可吐下，吐下則驚悸，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論辯證廣注",
      "chapter_title": "",
      "source_unit_id": "SU_B41512D4B_001666",
      "evidence_span": "又如病患兩手脈浮數而緩。名曰中風。若寸脈力小。（云云文同前）宜薄荷湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "",
      "source_unit_id": "SU_BC2BA03C0_000060",
      "evidence_span": "少陽中風，兩耳微聞，目赤，胸中滿而煩，不可吐下，吐下則驚悸，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "",
      "source_unit_id": "SU_BC2BA03C0_000060",
      "evidence_span": "少陽中風，兩耳微聞，目赤，胸中滿而煩，不可吐下，吐下則驚悸，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000728",
      "evidence_span": "中風發熱，六七日不解而煩，有表裡症，渴欲飲水，水入即吐，名曰水逆。五苓散主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000578",
      "evidence_span": "中風發熱，六七日不解而煩，有表裡症，渴欲飲水，水入即吐者，名曰水逆。五苓散主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000804",
      "evidence_span": "陽明中風。口苦咽乾，腹滿微喘，發熱惡寒，脈浮而緊。若下之，則腹滿小便難，麻黃湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論",
      "chapter_title": "",
      "source_unit_id": "SU_B5FF1CA1B_001255",
      "evidence_span": "則陽氣不足澀。則無血陽氣反微中風汗出而反躁煩澀則無血厥而且寒陽微不可下下之則心下痞硬。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000127",
      "evidence_span": "中風發熱，六七日，不解而煩，有表裡症，渴欲飲水，水入即吐者，名曰水逆，五苓散主之，多服暖水，汗出則愈。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000426",
      "evidence_span": "婦人中風七八日，續得寒熱，發作有時，經水適斷者，此為熱入血室，其血必結，故使如瘧狀，發作有時，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "",
      "source_unit_id": "SU_BC2BA03C0_000309",
      "evidence_span": "婦人中風七八日，續自寒熱，發作有時，經水適斷者，此為熱入血室，其血必結，故使如瘧狀，發作有時，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_001979",
      "evidence_span": "婦人中風，七八日，續得寒熱，發作有時，經水適斷者，此為熱入血室，其血必結，故使如瘧狀，發作有時，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001072",
      "evidence_span": "**十九、婦人中風，七八日續得寒熱，發作有時，經水適斷者，此為熱入血室，其血必結，故使如瘧狀，發作有時，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_002087",
      "evidence_span": "服桂枝湯不解，刺風池風府。（風池二穴足少陽陽維之會在項後髮際陷中風府一穴督脈陽維之會在項後入髮際一寸大筋宛中禁不可灸）",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_001656",
      "evidence_span": "陽明中風，脈弦浮大而短氣，腹都滿，脅下及心痛，久按之氣不通，鼻干，不得汗，嗜臥，一身及面目悉黃，小便難，有潮熱，時時噦。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒附翼",
      "chapter_title": "",
      "source_unit_id": "SU_B434348CD_000208",
      "evidence_span": "則少陰中風，脈陽微陰浮者，為欲愈，非必須陰出之陽而解耶。然必細審其脈沉而無裡症者，可發汗，即知脈沉而症為在裡者，不可發汗矣。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "",
      "source_unit_id": "SU_BC2BA03C0_000313",
      "evidence_span": "陽明中風，脈浮弦大而短氣，腹滿，脅下及心痛，久按之氣不通，鼻干不得汗，嗜臥，一身及目悉黃，小便難，有潮熱，時時噦，耳前後腫。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_001023",
      "evidence_span": "【鄭論】　按少陽屬相火，今得中風，風火相煽，壅於上竅則耳聾目赤，壅於胸中則滿而煩躁，當此時也，正當小柴胡加開鬱清火去風之品，切切不可吐下。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
