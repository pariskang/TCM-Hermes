    {
      "book_title": "傷寒論綱目",
      "chapter_title": "痞滿",
      "source_unit_id": "SU_B3E16D849_002986",
      "evidence_span": "小便不利譫語。一身盡重。不可轉側者。柴胡龍骨牡蠣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒總病論",
      "chapter_title": "發汗吐下後雜病證",
      "source_unit_id": "SU_B3E520529_000133",
      "evidence_span": "傷寒若吐下後，七八日不解，熱結在裏，表裏俱熱，時時惡風，大渴舌上乾燥而煩，飲水至數升者，白虎加人參主之。方在厥陰證中傷寒八九日，下之胸滿煩驚，小便不利，讝語重，不可轉側者，柴胡龍骨牡蠣湯主之，柴胡〔貳兩〕、龍骨、黃芩、生薑、鈆丹、人參、桂枝、茯苓、牡蠣〔各參分〕、半夏〔壹合〕、大黃〔壹兩〕、棗〔陸個〕，㕮咀，水六升煎取三升，下大黃，切如棋子塊，更煎取貳升，去滓，溫飲一盞。",
      "release_level": "silver"
    }
