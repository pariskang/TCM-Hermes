  "original_evidence": [
    {
      "book_title": "外感溫熱篇",
      "chapter_title": "陳平伯外感溫病篇",
      "dynasty": "清",
      "source_unit_id": "SU_BE94D1857_000015",
      "entry_id": "WARM_DISEASE_001314",
      "evidence_span": "風溫證身大熱，口大渴，目赤脣腫，氣粗煩躁，舌絳齒板痰欬，甚至神昏讝語，下利黃水者，風溫熱毒，深入陽明營分，最為危候，用犀角連翹葛根元參赤芍丹皮麥冬紫草川貝人中黃，解毒提斑，間有生者。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "治時病常變須會通論",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_001151",
      "entry_id": "WARM_DISEASE_000148",
      "evidence_span": "如春溫條中，有舌絳齒燥，譫語神昏，手足螈　，昏憒不語之變；",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病指南",
      "chapter_title": "濕溫中焦篇",
      "dynasty": "清",
      "source_unit_id": "SU_B466CAE95_000484",
      "entry_id": "WARM_DISEASE_000265",
      "evidence_span": "暑溫蔓延三焦。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病條辨",
      "chapter_title": "暑溫、伏暑",
      "dynasty": "清",
      "source_unit_id": "SU_BE393921E_000587",
      "entry_id": "WARM_DISEASE_001160",
      "evidence_span": "四一、暑溫蔓延三焦，舌滑微黃，邪在氣分者，三石湯主之；",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "冬溫條辨第七",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000306",
      "entry_id": "WARM_DISEASE_000453",
      "evidence_span": "冬溫煩熱，舌絳，神昏譫妄，斑紫或黑，脈數或促，此邪入血分。",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "斑疹條辨第五",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000394",
      "entry_id": "WARM_DISEASE_000476",
      "evidence_span": "《溫熱論》所謂衛之後方言氣，營之後方言血。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱經緯",
