    {
      "book_title": "金匱玉函經二註",
      "chapter_title": "",
      "source_unit_id": "SU_JGYH_ERZHU_001862",
      "evidence_span": "其人喜忘者。必有蓄血。大便黑色。抵當湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒捷訣",
      "chapter_title": "",
      "source_unit_id": "SU_B18FAB5FB_000071",
      "evidence_span": "小便利。大便黑。此蓄血症也。宜桃仁承氣湯及犀角地黃湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "",
      "source_unit_id": "SU_SHL_QJYF_000225",
      "evidence_span": "陽明證，其人喜忘，必有蓄血，所以然者，本有久瘀血，故令喜忘，雖堅，大便必黑，抵當湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_001033",
      "evidence_span": "若小便不利者，或是氣結溺澀，非蓄血症。若小便自利，兼有身黃目黃，如狂喜忘，漱水不得下咽等症，即是蓄血，急以桃仁承氣湯、抵當湯下之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_001033",
      "evidence_span": "按蓄血治法，有上中下三條。傷寒失汗，淤其血於上焦，用犀角地黃湯；如狂喜忘，心下滿，淤其血於中焦，桃仁承氣湯；小腹硬痛，小便自利，淤其血於下焦，抵當湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒六書",
      "chapter_title": "",
      "source_unit_id": "SU_BBA9FB4A6_000248",
      "evidence_span": "不愈，用桂枝湯。陽明下血譫語，胸滿如結胸，夜則如見鬼，此為熱入血室，小柴胡湯。下焦蓄血，其人如狂，小腹急結，小便自利，大便黑，與夫下利，無表裡證，脈數不解，消穀易飢，多日不大便，此為瘀血，桃仁承氣湯。少陰病，下利膿血，或腹滿，下如魚腦者，桃花湯主之。",
      "release_level": "silver"
    }
  ],
