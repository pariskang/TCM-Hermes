  "original_evidence": [
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "",
      "source_unit_id": "SU_SHL_QJYF_000152",
      "evidence_span": "陽明之為病，胃中寒是也。",
      "release_level": "gold"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000947",
      "evidence_span": "陽明病，汗多而渴者，不可與豬苓湯。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000770",
      "evidence_span": "**十三、陽明病，心下鞭滿者，不可攻之；",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000841",
      "evidence_span": "**三十三、陽明病，面合色赤，不可攻之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000544",
      "evidence_span": "陽明病，譫語發潮熱，脈滑而疾者，小承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000637",
      "evidence_span": "陽明病譫語，發潮熱，脈滑而疾者，小承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論綱目",
      "chapter_title": "",
      "source_unit_id": "SU_B3E16D849_002307",
      "evidence_span": "陽明病。若渴欲飲水。口乾舌燥者。白虎加人參湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000920",
      "evidence_span": "**十六、陽明病，譫語發潮熱，脈滑而疾者，小承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000305",
      "evidence_span": "陽明病，面含赤色，不可攻之，政之必發熱身黃，小便不利也。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000751",
      "evidence_span": "陽明病，發潮熱大便溏，小便自可胸脇不去者，小柴胡湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
      "source_unit_id": "SU_B11498305_000321",
      "evidence_span": "陽明病，心下鞕滿者，不可攻之，攻之利遂不止者，死利止者愈。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒尋源",
      "chapter_title": "",
      "source_unit_id": "SU_B8E444005_000233",
      "evidence_span": "又非吐法所能除。經云。陽明病不吐不下心煩者。調胃承氣湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒大白",
      "chapter_title": "",
      "source_unit_id": "SU_B9119D083_000160",
      "evidence_span": "陽明病，若汗多，微發熱惡寒者，外未解也，其熱不潮，未可與承氣湯。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論辯證廣注",
      "chapter_title": "",
      "source_unit_id": "SU_B41512D4B_001529",
      "evidence_span": "（重出例）陽明病下之其外有熱。（云云至）但頭汗出者。梔子豉湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "",
      "source_unit_id": "SU_B0B74DF58_000908",
      "evidence_span": "**十二、陽明病，潮熱，大便微鞕者，可與大承氣湯，不鞕者，不可與之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒纘論·傷寒緒論",
      "chapter_title": "",
