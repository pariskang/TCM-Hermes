    {
      "book_title": "傷寒論綱目",
      "chapter_title": "發熱",
      "source_unit_id": "SU_B3E16D849_000595",
      "evidence_span": "麻黃連翹赤小豆湯主之。傷寒身黃。發熱者。梔子柏皮湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論綱目",
      "chapter_title": "發黃",
      "source_unit_id": "SU_B3E16D849_001316",
      "evidence_span": "腹微滿者。茵陳蒿湯主之。傷寒身黃發熱者。梔子柏皮湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "張卿子傷寒論",
      "chapter_title": "辨濕脈證第四",
      "source_unit_id": "SU_B1CAC3ADF_000687",
      "evidence_span": "此身色如似熏黃。即非陽明瘀熱。身黃發熱者。梔子柏皮湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒溯源集",
      "chapter_title": "正陽陽明證治第十二",
      "source_unit_id": "SU_SHL_SUYUAN_001900",
      "evidence_span": "是熱勝於濕。無形之邪鬱蒸而發黃也。故不必茵陳大黃。而以梔子柏皮湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒醫訣串解",
      "chapter_title": "陽明篇",
      "source_unit_id": "SU_BF5CDC206_000088",
      "evidence_span": "以大黃合茵陳蒿導之從小便出也。七十八節云。傷寒身黃發熱者。梔子柏皮湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒論(千金翼方)",
      "chapter_title": "陽明病狀第八",
      "source_unit_id": "SU_SHL_QJYF_000232",
      "evidence_span": "傷寒發其汗，則身目為黃，所以然者，寒濕相搏，在裡不解故也。傷寒其人發黃，梔子柏皮湯主之。",
      "release_level": "silver"
    },
    {
      "book_title": "註解傷寒論",
      "chapter_title": "辨濕脈證第四",
      "source_unit_id": "SU_SHL_ZHUJIE_000448",
      "evidence_span": "身黃如橘子色者，陽明瘀熱也。此身色如似熏黃，即非陽明瘀熱。身黃發熱者，梔子柏皮湯主之，為表裡有熱，則身不疼痛。",
      "release_level": "silver"
    },
    {
      "book_title": "傷寒恆論",
      "chapter_title": "陽明上篇",
      "source_unit_id": "SU_B0B74DF58_000849",
      "evidence_span": "【闡釋】　陽明病，無汗，本應以葛根湯發其汗，今竟以火劫取汗，則熱邪愈熾，津液被束，無復外布與下滲矣，其身必發黃。原文未出方治，根據辨證，必須清熱利濕，梔子柏皮湯主之。",
      "release_level": "silver"
    }
