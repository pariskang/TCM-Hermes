  "original_evidence": [
    {
      "book_title": "時病論",
      "chapter_title": "冬溫",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_001090",
      "entry_id": "WARM_DISEASE_000137",
      "evidence_span": "或問：冬溫發熱而不惡寒，倘惡寒者，為何病也？",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "二十六、溫暑伏氣證狀",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000353",
      "entry_id": "WARM_DISEASE_000691",
      "evidence_span": "伏氣溫病，自裡出表，乃先從血分，而後達於氣分。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病指南",
      "chapter_title": "濕溫上焦篇",
      "dynasty": "清",
      "source_unit_id": "SU_B466CAE95_000370",
      "entry_id": "WARM_DISEASE_000245",
      "evidence_span": "暑溫初起頭。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "八、冬溫",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000513",
      "entry_id": "WARM_DISEASE_000792",
      "evidence_span": "又或問曰：冬溫發熱而不惡寒，倘惡寒者，為何病也？",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱逢源",
      "chapter_title": "伏溫化熱內陷手足厥陰發痙厥昏蒙等證",
      "dynasty": "清",
      "source_unit_id": "SU_BBDFA4EA7_000401",
      "entry_id": "WARM_DISEASE_000967",
      "evidence_span": "惟有伏邪已動，而熱象鬱滯，不達於三陽，亦不歸於胃腑，而即竄入厥陰者，在手厥陰則神昏譫語，煩躁不寐，甚則狂言無序，或蒙閉不語。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "溫病",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000021",
      "entry_id": "WARM_DISEASE_000009",
      "evidence_span": "嘗謂介賓之書，謂溫病即傷寒，治分六要五忌；",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_001010",
      "entry_id": "WARM_DISEASE_000126",
      "evidence_span": "微歙程其，年屆賜鳩，忽患濕溫之證，曾延醫治，一稱伏暑，一稱濕溫，一稱虛損，清利與補，皆未中鵠，始來商治於豐。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "十一、《傷寒緒論》",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000256",
      "entry_id": "WARM_DISEASE_000617",
      "evidence_span": "（一）至春分節後，天令溫暖，有人壯熱為病者。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱逢源",
      "chapter_title": "辨正張石頑傷寒緒論溫熱各條",
      "dynasty": "清",
      "source_unit_id": "SU_BBDFA4EA7_000287",
      "entry_id": "WARM_DISEASE_000928",
      "evidence_span": "至春分節後，天令溫暖，有人壯熱為病者，乃溫病也。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000137",
      "entry_id": "WARM_DISEASE_000060",
      "evidence_span": "海昌張某，於暮春之初，突然壯熱而渴，曾延醫治，胥未中機。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "濕溫",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000911",
      "entry_id": "WARM_DISEASE_000111",
      "evidence_span": "有言素傷於濕，因而中暑，暑濕相搏，名曰濕溫，據此而論，是病又在乎夏。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "二十一、論溫病與傷寒病情不同治法各異",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000345",
      "entry_id": "WARM_DISEASE_000683",
      "evidence_span": "若夫溫病，乃冬時寒邪伏於少陰，迨春夏陽氣內動，伏邪化而為熱，由少陰而外出，如邪出太陽，亦見太陽經證，其頭項強痛等象，亦與傷寒同。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病條辨",
      "chapter_title": "風溫、溫熱、溫疫、溫毒、冬溫",
      "dynasty": "清",
      "source_unit_id": "SU_BE393921E_000390",
      "entry_id": "WARM_DISEASE_001108",
      "evidence_span": "（按《靈樞》論諸臟溫病，獨肺溫病有舌苔之明文，余則無有。",
      "release_level": "bronze"
    },
    {
      "book_title": "增訂葉評傷暑全書",
      "chapter_title": "暑風",
      "dynasty": "",
      "source_unit_id": "SU_BE7000B4E_000033",
      "entry_id": "WARM_DISEASE_001261",
      "evidence_span": "痙甚則厥，近世雖嚴寒溫之防，而取重於安宮、至寶、清營、紫雪之類，全是溫病伏氣，治法與中暑之痙厥，究隔一間。",
      "release_level": "bronze"
    },
    {
      "book_title": "外感溫熱篇",
      "chapter_title": "陳平伯外感溫病篇",
      "dynasty": "清",
      "source_unit_id": "SU_BE94D1857_000009",
      "entry_id": "WARM_DISEASE_001309",
      "evidence_span": "風溫證身熱欬嗽，口渴下利，苔黃讝語，胸痞脈數，此溫邪由肺胃下注大腸，當用黃苓桔梗煨葛豆卷甘草橘皮之屬，以升泄溫邪。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病指南",
      "chapter_title": "濕溫上焦篇",
      "dynasty": "清",
      "source_unit_id": "SU_B466CAE95_000383",
      "entry_id": "WARM_DISEASE_000246",
      "evidence_span": "手太陰暑溫。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病條辨",
      "chapter_title": "伏暑",
      "dynasty": "清",
      "source_unit_id": "SU_BE393921E_000212",
      "entry_id": "WARM_DISEASE_001085",
      "evidence_span": "四十、太陰伏暑、舌白口渴，有汗，或大汗不止者，銀翹散去牛蒡子、元參、芥穗，加杏仁、石膏、黃芩主之；",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病指南",
      "chapter_title": "濕溫下焦篇",
      "dynasty": "清",
      "source_unit_id": "SU_B466CAE95_000503",
      "entry_id": "WARM_DISEASE_000269",
      "evidence_span": "濕溫病身熱久不解。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病條辨",
      "chapter_title": "風溫、溫熱、溫疫、溫毒、冬溫",
      "dynasty": "清",
      "source_unit_id": "SU_BE393921E_000389",
      "entry_id": "WARM_DISEASE_001107",
      "evidence_span": "一、面目俱赤，語聲重濁，呼吸俱粗，大便閉，小便澀，舌苔老黃，甚則黑有芒刺，但惡熱，不惡寒，日晡益甚者，傳至中焦，陽明溫病也。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱經緯",
      "chapter_title": "葉香岩外感溫熱篇",
      "dynasty": "清",
      "source_unit_id": "SU_BFAA96A43_000347",
      "entry_id": "WARM_DISEASE_001385",
      "evidence_span": "傳至陽明，其邪化熱，則不惡寒，始可用涼解之法。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "臨證治案",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000129",
      "entry_id": "WARM_DISEASE_000052",
      "evidence_span": "今見大汗身涼，而用沙參細地，能不令人駭然？",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱暑疫全書",
      "chapter_title": "春溫病論",
      "dynasty": "清",
      "source_unit_id": "SU_B556232D1_000099",
      "entry_id": "WARM_DISEASE_000306",
      "evidence_span": "有人壯熱為病者。",
      "release_level": "bronze"
    },
    {
      "book_title": "六因條辨",
      "chapter_title": "風溫條辨第三",
      "dynasty": "清",
      "source_unit_id": "SU_B621466F9_000378",
      "entry_id": "WARM_DISEASE_000471",
      "evidence_span": "風溫一二日後，神反清，語反出，舌黃口渴，煩熱脈洪，此溫邪內蒸。",
      "release_level": "bronze"
    },
    {
      "book_title": "時病論",
      "chapter_title": "熱病",
      "dynasty": "清",
      "source_unit_id": "SU_B29F50239_000486",
      "entry_id": "WARM_DISEASE_001558",
      "evidence_span": "倪氏謂：交立夏以來，久伏之氣，隨時令之熱而觸發，故初病即發熱汗出，口渴心煩，不惡寒而反惡熱，脈來洪大之象，是為熱病也。",
      "release_level": "bronze"
    }
  ],
