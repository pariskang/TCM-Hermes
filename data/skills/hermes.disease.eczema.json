  "supporting_rules_by_release_level": {},
  "original_evidence": [
    {
      "book_title": "瘍醫大全",
      "chapter_title": "結毒門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_013406",
      "entry_id": "ECZEMA_000057",
      "evidence_span": "一、頭面、胸背並四肢有生硬片，狀如牛皮，初癢及抓則起白屑而麻痛，此輕粉之結毒也，切勿作癬治。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "諸瘡論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_000856",
      "entry_id": "ECZEMA_000067",
      "evidence_span": "若或生於手足間，相對如新茱萸，癢痛坼裂，搔破則黃水淋漓，有孔如　，久而生蟲，是為　瘡。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "四彎風門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_010097",
      "entry_id": "ECZEMA_000034",
      "evidence_span": "《心法》曰：四彎風，生於兩腿彎及兩腳拗，每月一發，形如風癬，乃風邪襲入腠理而成。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "月蝕疳瘡門主論",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_005341",
      "entry_id": "ECZEMA_000028",
      "evidence_span": "《心法》曰：月蝕瘡，又名旋耳瘡，生於耳後縫間，延及耳折上下，如刀裂之狀，色紅時流津黃水。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "諸疳瘡論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_000748",
      "entry_id": "ECZEMA_000066",
      "evidence_span": "初生如疥癬，破時黃水浸淫成瘡，風濕相搏，毒瓦斯聚攻，漸生遍體。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "諸瘡論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_000878",
      "entry_id": "ECZEMA_000068",
      "evidence_span": "治面上耳邊生浸淫瘡，有黃水出，久不愈。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科集驗方",
      "chapter_title": "疥癬論",
      "dynasty": "明",
      "source_unit_id": "SU_B6F997274_001050",
      "entry_id": "ECZEMA_000070",
      "evidence_span": "久而不愈，延及遍身，浸淫潰爛，或癢或痛，其狀不一，二者皆有細蟲而能傳染人也。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍科心得集",
      "chapter_title": "辨膿窠瘡黃水瘡論",
      "dynasty": "清",
      "source_unit_id": "SU_BB130CD90_000249",
      "entry_id": "ECZEMA_000103",
      "evidence_span": "黃水瘡者，頭面耳項，忽生黃泡，破流脂水，頃刻沿開，多生痛癢。",
      "release_level": "bronze"
    },
    {
      "book_title": "瘍醫大全",
      "chapter_title": "奶癬瘡門主方",
      "dynasty": "清",
      "source_unit_id": "SU_B66C51E14_011711",
      "entry_id": "ECZEMA_000047",
      "evidence_span": "小兒奶癬及滿頭遍身黃水瘡，白面不拘多少，香油拌勻作HT　，火燒成性為末，再用真香油調搓。",
      "release_level": "bronze"
    }
  ],
