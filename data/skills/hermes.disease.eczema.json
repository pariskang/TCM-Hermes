  "original_evidence": [
    {
      "book_title": "醫宗金鑒",
      "chapter_title": "外科心法要訣·胎斂瘡",
      "dynasty": "清",
      "source_unit_id": "SU_ECZEMA_SAMPLE_0005",
      "entry_id": "ECZEMA_000004",
      "evidence_span": "胎斂瘡，又名奶癬，生嬰兒頭頂或眉端，癢起白屑，形如癬疥，由胎中血熱，落草受風纏綿。",
      "release_level": "silver"
    },
    {
      "book_title": "外科正宗",
      "chapter_title": "黃水瘡",
      "dynasty": "明",
      "source_unit_id": "SU_ECZEMA_SAMPLE_0006",
      "entry_id": "ECZEMA_000005",
      "evidence_span": "黃水瘡者，於頭面耳項忽生黃皰，破流脂水，浸淫成片，隨處可生，由脾胃濕熱所致。",
      "release_level": "silver"
    },
    {
      "book_title": "瘍科心得集",
      "chapter_title": "辨濕瘡",
      "dynasty": "清",
      "source_unit_id": "SU_ECZEMA_SAMPLE_0007",
      "entry_id": "ECZEMA_000006",
      "evidence_span": "濕瘡者，遍身起疹，搔癢流水，浸淫日廣，由濕熱內蘊、外受風邪，治宜清熱利濕、祛風止癢。",
      "release_level": "bronze"
    },
    {
      "book_title": "外科證治全書",
      "chapter_title": "血風瘡",
      "dynasty": "清",
      "source_unit_id": "SU_ECZEMA_SAMPLE_0008",
      "entry_id": "ECZEMA_000007",
      "evidence_span": "血風瘡，遍身瘙癢，搔破津血水，日久肌膚乾燥脫屑，由血虛風燥、濕熱相搏所致，治宜養血潤燥、清熱祛風。",
      "release_level": "bronze"
    },
    {
      "book_title": "醫宗金鑒",
      "chapter_title": "外科心法要訣·浸淫瘡",
      "dynasty": "清",
      "source_unit_id": "SU_ECZEMA_SAMPLE_0002",
      "entry_id": "ECZEMA_000008",
      "evidence_span": "此證初生如疥，搔癢無時，蔓延不止，抓津黃水，浸淫成片，由心火脾濕受風而成。",
      "release_level": "bronze"
    },
    {
      "book_title": "醫宗金鑒",
      "chapter_title": "外科心法要訣·四彎風",
      "dynasty": "清",
      "source_unit_id": "SU_ECZEMA_SAMPLE_0004",
      "entry_id": "ECZEMA_000003",
      "evidence_span": "四彎風，生於兩腿彎、腳彎，每月一發，形如風癬，屬風邪襲入腠理，其癢無度，搔破津水。",
      "release_level": "bronze"
    },
    {
      "book_title": "醫宗金鑒",
      "chapter_title": "外科心法要訣·旋耳瘡",
      "dynasty": "清",
      "source_unit_id": "SU_ECZEMA_SAMPLE_0003",
      "entry_id": "ECZEMA_000002",
      "evidence_span": "旋耳瘡，生於耳後縫間，色紅作癢，破流脂水，纏綿難愈，由膽脾濕熱所致。",
      "release_level": "bronze"
    }
