  "original_evidence": [
    {
      "book_title": "溫病指南",
      "chapter_title": "濕溫中焦篇",
      "dynasty": "清",
      "source_unit_id": "SU_B466CAE95_000491",
      "entry_id": "WARM_DISEASE_000266",
      "evidence_span": "暑溫伏暑。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病正宗",
      "chapter_title": "三、熱病辨脈",
      "dynasty": "",
      "source_unit_id": "SU_B6FF8FB50_000402",
      "entry_id": "WARM_DISEASE_000725",
      "evidence_span": "大抵熱病比溫病尤加熱也，脈得洪大有力，或滑數有力，乃為病脈相應，謂之可治；",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱逢源",
      "chapter_title": "伏溫熱結胃腑證治",
      "dynasty": "清",
      "source_unit_id": "SU_BBDFA4EA7_000381",
      "entry_id": "WARM_DISEASE_000961",
      "evidence_span": "故溫熱病熱結胃腑，得攻下而解者，十居六七。",
      "release_level": "bronze"
    },
    {
      "book_title": "外感溫熱篇",
      "chapter_title": "陳平伯外感溫病篇",
      "dynasty": "清",
      "source_unit_id": "SU_BE94D1857_000008",
      "entry_id": "WARM_DISEASE_001308",
      "evidence_span": "風溫證身灼熱，口大渴，欬嗽煩悶，讝語如夢語，脈絃收乾嘔者，此熱灼肺胃，風火內旋，當用羚羊川貝連翹麥冬石斛青蒿知母花粉之屬，以泄熱和陰。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病條辨",
      "chapter_title": "暑溫",
      "dynasty": "清",
      "source_unit_id": "SU_BE393921E_000157",
      "entry_id": "WARM_DISEASE_001065",
      "evidence_span": "二六、手太陰暑溫，或已經發汗，或未發汗，而汗不止，煩渴而喘，脈洪大有力者，白虎湯主之；",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病條辨",
      "chapter_title": "暑溫、伏暑",
      "dynasty": "清",
      "source_unit_id": "SU_BE393921E_000597",
      "entry_id": "WARM_DISEASE_001161",
      "evidence_span": "四二、暑溫伏暑，三焦均受，舌灰白，胸痞悶，潮熱嘔惡，煩渴自利，汗出溺短者，杏仁滑石湯主之。",
      "release_level": "bronze"
    },
    {
      "book_title": "溫病條辨",
      "chapter_title": "風溫、溫熱、溫疫、溫毒、冬溫",
      "dynasty": "清",
      "source_unit_id": "SU_BE393921E_001004",
      "entry_id": "WARM_DISEASE_001175",
      "evidence_span": "一、風溫、溫熱、溫疫、溫毒、冬溫，邪在陽明久羈，或已下，或未下，身熱面赤，口乾舌燥，甚則齒黑唇裂，脈沉實者，仍可下之；",
      "release_level": "bronze"
    },
    {
      "book_title": "溫熱逢源",
      "chapter_title": "伏溫由少陰外達三陽證治",
      "dynasty": "清",
      "source_unit_id": "SU_BBDFA4EA7_000380",
      "entry_id": "WARM_DISEASE_000960",
      "evidence_span": "太陽則惡寒發熱，頭項疼，腰脊強，治宜豉、芩，合陽旦湯。",
      "release_level": "bronze"
    }
  ],
